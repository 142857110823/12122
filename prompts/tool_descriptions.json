  {
    "type": "function",
    "function": {
      "name": "prepare_run_context",
      "description": "Initialize run context and evidence tree under data/runs/<run_id>.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_mode": {
            "type": "string",
            "enum": [
              "quick",
              "full"
            ],
            "description": "Workflow depth mode."
          },
          "source_mode": {
            "type": "string",
            "enum": [
              "rusle_raw",
              "uploads"
            ],
            "description": "Data source mode."
          },
          "output_dpi": {
            "type": "integer",
            "description": "Figure output DPI, default 300."
          },
          "run_id": {
            "type": "string",
            "description": "Optional external run id."
          },
          "cleanup_history": {
            "type": "boolean",
            "description": "Whether to cleanup old runs safely."
          },
          "max_keep_runs": {
            "type": "integer",
            "description": "Max run folders to keep when cleanup is enabled."
          },
          "source_dir": {
            "type": "string",
            "description": "Optional raw source directory override."
          }
        },
        "required": []
      }
    }
  },
