  {
    "type": "function",
    "function": {
      "name": "run_full_tile_coverage_probe",
      "description": "Probe a bounded set of full-mode spatial tiles, execute tile preprocessing where safe, and write a coverage report with success/failure accounting.",
      "parameters": {
        "type": "object",
        "properties": {
          "plan_path": {
            "type": "string",
            "description": "Optional full_execution_plan.json path."
          },
          "tile_plan_path": {
            "type": "string",
            "description": "Optional spatial tile plan path."
          },
          "tile_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Explicit tile ids to probe."
          },
          "tile_start_index": {
            "type": "integer",
            "description": "First tile index when tile_ids is omitted."
          },
          "tile_count": {
            "type": "integer",
            "description": "Number of strided tiles to probe when tile_ids is omitted."
          },
          "tile_stride": {
            "type": "integer",
            "description": "Tile index stride when tile_ids is omitted."
          },
          "year": {
            "type": "string",
            "description": "Target year inside the batch."
          },
          "max_tile_pixels": {
            "type": "integer",
            "description": "Maximum pixels per tile allowed for preprocessing."
          },
          "max_records_per_tile": {
            "type": "integer",
            "description": "Maximum sampled records to write per successful tile."
          },
          "max_probe_tiles": {
            "type": "integer",
            "description": "Hard cap on number of tiles per probe call."
          },
          "run_id": {
            "type": "string",
            "description": "Optional run id."
          }
        },
        "required": []
      }
    }
