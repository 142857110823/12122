          },
          "max_source_size_gb": {
            "type": "number",
            "description": "Maximum estimated batch source size allowed for execution."
          },
          "max_pixels": {
            "type": "integer",
            "description": "Maximum raster pixel count allowed for execution."
          },
          "run_id": {
            "type": "string",
            "description": "Optional run id."
          }
        },
        "required": []
      }
